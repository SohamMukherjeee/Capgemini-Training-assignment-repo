<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:p="http://www.springframework.org/schema/p"
	xmlns:c="http://www.springframework.org/schema/c"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

	<bean id="address" class="com.capgemini.mangSystem.EmployeeManagement.Address">
		<constructor-arg value="1"></constructor-arg>
		<constructor-arg value="Bangalore"></constructor-arg>
		<constructor-arg value="Karnataka"></constructor-arg>
		<constructor-arg value="India"></constructor-arg>
		<constructor-arg value="560001"></constructor-arg>
	</bean>
    
	<bean id="employee" class="com.capgemini.mangSystem.EmployeeManagement.Employee" autowire="byName">
		<property name="id" value="101"></property>
		<property name="name" value="Mike"></property>
		<property name="email" value="mike@gmail.com"></property>
		<property name="password" value="mike@123"></property>
		<property name="age" value="28"></property>
		<property name="salary" value="60000"></property>
	</bean>

	<bean id="employeeService" class="com.capgemini.mangSystem.EmployeeManagement.EmployeeServiceImpl" autowire="byName">
	</bean>
</beans>