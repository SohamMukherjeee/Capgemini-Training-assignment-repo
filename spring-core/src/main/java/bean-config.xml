<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:p="http://www.springframework.org/schema/p"
	xmlns:c="http://www.springframework.org/schema/c"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

	<!-- bean definitions here -->
	<bean name="user" class="com.capgemini.spring_core.User" autowire="byName">
		<property name="id" value="123"></property>
		<property name="name" value="Soham"></property>
		<property name="email" value="sohamnaz@gmail.com"></property>
	</bean>
		<bean name="user1" class="com.capgemini.spring_core.User">
		<property name="id" value="13"></property>
		<property name="name" value="Ram"></property>
		<property name="email" value="Ramz@gmail.com"></property>
		<property name="employee" ref="employee"></property>
	</bean>


	<bean id="employee" class="com.capgemini.spring_core.Employee">
	<constructor-arg value="12"></constructor-arg>
	<constructor-arg value="Soham"></constructor-arg>
	<constructor-arg value="ALpha Male"></constructor-arg>
	<constructor-arg value="12000.1"></constructor-arg>
	</bean>
	
	<bean name="pojo" class="com.capgemini.spring_core.PojoClass" autowire="byName">
	</bean>

</beans>